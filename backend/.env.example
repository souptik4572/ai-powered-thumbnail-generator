OPENAI_API_KEY=sk-...
IMAGEKIT_PRIVATE_KEY=private_...
IMAGEKIT_PUBLIC_KEY=public_...
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/<your-id>

# ---------------------------------------------------------------------------
# DATABASE_URL — choose one format depending on your database
# ---------------------------------------------------------------------------
# SQLite (default, no extra package needed):
DATABASE_URL="sqlite:///./thumbnailbuilder.db"

# PostgreSQL (requires: pip install "psycopg[binary]"):
# DATABASE_URL="postgresql+psycopg://user:password@host:5432/dbname"

# MySQL / MariaDB (requires: pip install PyMySQL):
# DATABASE_URL="mysql+pymysql://user:password@host:3306/dbname"
# ---------------------------------------------------------------------------

ACCESS_SECRET_TOKEN=<random-hex-secret>
BCRYPT_SALT=5
JWT_ALGORITHM=ALGORITHM
MAX_USERS=100

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
